{
	"compilerOptions": {
		"module": "ES2020",
		"target": "ES2020",
		"outDir": "dist",
		"lib": [
			"ES2020"
		],
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "node"
	}
}
